{
  // Переопределение моделей для агентов.
  "agents": {
    "sisyphus": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "medium",
      "displayName": "Nexus",
      "description": "Центральный оркестратор. Планирует, декомпозирует задачи, делегирует агентам-специалистам, контролирует качество. Не пишет код — обеспечивает слаженную работу всей системы.",
    },
    "hephaestus": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "high",
      "displayName": "Forge",
      "description": "Автономный deep-исполнитель. Получает цель, исследует кодовую базу, изучает паттерны и выполняет задачу от начала до конца без микроменеджмента.",
    },
    "prometheus": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "max",
      "displayName": "Architect",
      "description": "Стратегический планировщик. Проводит интервью, уточняет требования и строит детальный план до того, как написана хоть одна строка кода.",
    },
    "sisyphus-junior": {
      "model": "opencode/kimi-k2.6",
      "reasoningEffort": "medium",
      "displayName": "Drone",
      "description": "Сфокусированный исполнитель. Получает атомарную задачу с чёткими границами и выполняет её. Без планирования, без делегирования — чистое исполнение. Используется в том числе для git-коммитов.",
    },
    "oracle": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "max",
      "displayName": "Oracle",
      "description": "Консультант только для чтения. Разбирается в сложной архитектуре, находит корневые причины багов, даёт высокоуровневые рассуждения по трудным проблемам.",
    },
    "metis": {
      "model": "opencode/kimi-k2.7",
      "reasoningEffort": "high",
      "displayName": "Scanner",
      "description": "Аналитик перед планированием. Сканирует запросы до начала планирования, выявляя скрытые намерения, неоднозначности и потенциальные точки сбоя AI.",
    },
    "momus": {
      "model": "opencode/kimi-k2.7",
      "reasoningEffort": "high",
      "displayName": "Audit",
      "description": "Критик планов и качества. Оценивает планы работ и результаты по критериям ясности, проверяемости и полноты. Беспощаден к пробелам.",
    },
    "explore": {
      "model": "opencode/kimi-k2.6",
      "reasoningEffort": "minimal",
      "displayName": "Scout",
      "description": "Быстрый grep по кодовой базе. Отвечает на вопросы: где находится X? в каком файле Y? найди код, который делает Z. Лёгкий и параллельный.",
    },
    "librarian": {
      "model": "opencode/kimi-k2.6",
      "reasoningEffort": "minimal",
      "displayName": "Archive",
      "description": "Поиск внешних знаний. Ищет документацию, GitHub и веб для примеров использования библиотек, лучших практик и справки по API.",
    },
  },

  // Переопределение категорий Sisyphus-Junior.
  "categories": {
    // ★★★★★ Сложная логика, архитектура, длинный контекст.
    "ultrabrain": {
      "model": "opencode/glm-5.2",
      "reasoningEffort": "max",
    },

    // ★★★★ Автономный TypeScript-кодинг, генерация, рефакторинг.
    "deep": {
      "model": "opencode/kimi-k2.6",
      "reasoningEffort": "high",
    },

    // ★★★★ Креативные, нестандартные решения.
    "artistry": {
      "model": "opencode/minmax-m3",
      "reasoningEffort": "medium",
    },

    // ★★★ UI/UX, стили, фронтенд, vibe coding.
    "visual-engineering": {
      "model": "opencode/kimi-k2.6",
      "reasoningEffort": "medium",
    },

    // ★★★ Средние задачи без категории.
    "unspecified-high": {
      "model": "opencode/kimi-k2.6",
      "reasoningEffort": "medium",
    },

    // ★★ Документация, проза, техрайтинг.
    "writing": {
      "model": "opencode/glm-5.2",
      "reasoningEffort": "minimal",
    },

    // ★ Простые задачи без категории, стабильный ежедневный TS.
    "unspecified-low": {
      "model": "opencode/qwen-3",
      "reasoningEffort": "minimal",
    },

    // ★ Опечатки, мелкие правки, один файл.
    "quick": {
      "model": "opencode/kimi-k2.6",
      "reasoningEffort": "none",
    },
  },
}
